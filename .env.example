# Polymarket API Configuration
# Get your private key from your wallet (e.g., MetaMask) - export private key
# DO NOT SHARE THIS FILE OR COMMIT IT TO GITHUB
PRIVATE_KEY=your_private_key_here

# Optional: API Credentials (for higher rate limits/performance)
# Generate these using the CLOB client or dashboard
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# Trading Configuration
# Token ID of the market you want to trade (e.g. from Gamma API or URL)
TARGET_TOKEN_ID=

# Safety
DRY_RUN=True  # Set to False to execute real trades
