# ==================================================
# POLYMARKET TRADING BOT - CONFIGURATION
# ==================================================

# Copy this file to .env and fill in your values
# Lines starting with # are comments (ignored)

# ==================================================
# API CREDENTIALS (Optional for read-only mode)
# ==================================================

# Your Ethereum private key (64 hexadecimal characters).
# ⚠️ IMPORTANT: This must be pure hexadecimal (0-9, a-f, A-F) without hyphens.
# Example: PRIVATE_KEY=a1b2c3d4e5f67890abcdef1234567890abcdef1234567890abcdef1234567890
# Or with 0x prefix: PRIVATE_KEY=0xa1b2c3d4e5f67890abcdef1234567890abcdef1234567890abcdef1234567890
# Leave empty for read-only mode (monitoring only)
PRIVATE_KEY=

# Polymarket CLOB API credentials (optional - for advanced trading)
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# ==================================================
# TRADING PARAMETERS
# ==================================================

# Specific market token ID to monitor (optional)
# If set, this market will be added to the watchlist
TARGET_TOKEN_ID=

# Dry run mode (True = simulation only, False = live trading)
# ⚠️ WARNING: Set to False ONLY if you understand the risks
DRY_RUN=True

# ==================================================
# ALERT CONFIGURATION
# ==================================================

# Volatility threshold to trigger alerts (0.05 = 5% price change)
# Range: 0.001 to 1.0 (0.1% to 100%)
VOLATILITY_THRESHOLD=0.05

# Interval between price checks in SECONDS (default: 5)
# Lower values = more real-time but more API calls
# Range: 1 to 3600 (1 second to 1 hour)
CHECK_INTERVAL_SECONDS=5

# ==================================================
# TELEGRAM NOTIFICATIONS (Optional)
# ==================================================

# Get your bot token from @BotFather on Telegram
TELEGRAM_TOKEN=

# Your Telegram chat ID (get from @userinfobot)
TELEGRAM_CHAT_ID=

# ==================================================
# STRATEGY PARAMETERS (Advanced)
# ==================================================

# Market making spread (0.02 = 2%)
SPREAD=0.02

# Minimum spread to operate (0.005 = 0.5%)
MIN_SPREAD=0.005

# Order size in USDC
ORDER_SIZE=10.0

# Maximum position size in USDC
MAX_POSITION=50.0

# ==================================================
# NOTES
# ==================================================

# 1. For monitoring only (no trading):
#    - Leave PRIVATE_KEY empty
#    - Set DRY_RUN=True
#
# 2. For live trading:
#    - Set valid PRIVATE_KEY (64 hex characters)
#    - Set DRY_RUN=False
#    - ⚠️ Use at your own risk!
#
# 3. Real-time monitoring:
#    - Lower CHECK_INTERVAL_SECONDS for faster updates
#    - Default 5s = near real-time (vs old 10 minutes)
#
# 4. Telegram alerts:
#    - Optional but recommended for mobile notifications
#    - Create bot with @BotFather
#    - Get your chat ID from @userinfobot
